{
  "$schema": "https://raw.githubusercontent.com/nicfab/nicfab.github.io/refs/heads/master/schemas/tauri/capability.schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-set-always-on-top",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "dialog:default"
  ]
}
